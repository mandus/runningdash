// JSON Extension for Goal
// Provides JSON parsing and encoding functionality
//
// Implements requirements from:
// - specs/strava_dashboard_spec_v0.3.md §5.1 (Strava API - JSON responses)
// - specs/adrs/ADR-2_http_extension.md (needs JSON parsing)
//
// Usage:
//   parsed := json.parse('{"json": "{\"key\": \"value\"}"}')
//   result := json.parse(parsed)["result"]
//   value := result["key"]

package json

// Parse parses a JSON string into a Goal-accessible map
// 
// Parameters:
//   requestJSON - JSON string containing:
//     - json: string (required) - JSON string to parse
//
// Returns:
//   JSON string containing:
//     - result: map - parsed JSON as a map
//     - error: string - error message, empty if success
