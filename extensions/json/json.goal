}

// Encode encodes a Goal data structure to JSON string
// 
// Parameters:
//   requestJSON - JSON string containing:
//     - data: any - Goal data structure to encode
//
// Returns:
//   JSON string containing:
//     - json: string - encoded JSON string
//     - error: string - error message, empty if success
//
// Example:
//   # Encode a map to JSON
//   data := {"name": "test", "value": 123}
//   encoded := json.encode('{"data": ' + json.encode('{"data": ' + json.encode(data) + '}') + '}')
//   # Or simpler with explicit JSON:
//   encoded := json.encode('{"data": {"name": "test", "value": 123}}')
