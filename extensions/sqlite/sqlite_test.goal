// Tests for SQLite Goal extension
// Demonstrates that the extension works correctly
//
// Run with: goal run sqlite_test.goal

package main

import "db"
import "json"

func main() {
	// Test 1: Open database connection
	println("Test 1: Open database connection")
	openRequest := json.encode({
		"path": ":memory:"
	})
	openResponse := db.open(openRequest)
	parsed := json.parse(openResponse)
	
	if parsed["error"] != "" {
		println("ERROR: " + parsed["error"])
		return
	}
	
	connID := parsed["connection_id"]
	println("Connection ID: " + string(connID))
	println("Test 1: PASSED")
	println("")
	
	// Test 2: Create table and insert data
	println("Test 2: Create table and insert data")
	createSQL := `CREATE TABLE test (id INTEGER PRIMARY KEY, name TEXT)`
	execRequest := json.encode({
		"connection_id": connID,
		"sql": createSQL,
		"params": []
	})
	execResponse := db.exec(execRequest)
	parsedExec := json.parse(execResponse)
	
	if parsedExec["error"] != "" {
		println("ERROR: " + parsedExec["error"])
		return
	}
	
	println("Table created, affected: " + string(parsedExec["affected"]))
	
	// Insert data
	insertSQL := `INSERT INTO test (name) VALUES (?)`
	insertRequest := json.encode({
		"connection_id": connID,
		"sql": insertSQL,
		"params": ["test_value"]
	})
	insertResponse := db.exec(insertRequest)
	parsedInsert := json.parse(insertResponse)
	
	if parsedInsert["error"] != "" {
		println("ERROR: " + parsedInsert["error"])
		return
	}
	
	println("Data inserted, affected: " + string(parsedInsert["affected"]))
	println("Test 2: PASSED")
	println("")
	
	// Test 3: Query data
	println("Test 3: Query data")
	querySQL := `SELECT * FROM test`
	queryRequest := json.encode({
		"connection_id": connID,
		"sql": querySQL,
		"params": []
	})
	queryResponse := db.query(queryRequest)
	parsedQuery := json.parse(queryResponse)
	
	if parsedQuery["error"] != "" {
		println("ERROR: " + parsedQuery["error"])
		return
	}
	
	results := parsedQuery["results"]
	println("Query returned " + string(len(results)) + " rows")
	
	if len(results) > 0 {
		println("First row: " + string(results[0]))
	}
	
	println("Test 3: PASSED")
	println("")
	
	// Test 4: Close connection
	println("Test 4: Close connection")
	closeRequest := json.encode({
		"connection_id": connID
	})
	closeResponse := db.close(closeRequest)
	parsedClose := json.parse(closeResponse)
	
	if parsedClose["error"] != "" {
		println("ERROR: " + parsedClose["error"])
		return
	}
	
	println("Connection closed")
	println("Test 4: PASSED")
	println("")
	
	println("All SQLite extension tests passed!")
}
